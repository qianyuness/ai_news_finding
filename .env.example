LLM_PROVIDER=openai_compatible
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://your-provider.example/v1
LLM_MODEL=replace-with-your-model-name
LLM_REQUESTS_PER_MINUTE=12
LLM_MAX_WORKERS=2
LLM_MAX_CONCURRENCY=2
LLM_MAX_RETRIES=6
LLM_TIMEOUT_SECONDS=120

# Optional: set this instead of LLM_BASE_URL when your provider gives a full endpoint.
# LLM_API_URL=https://your-provider.example/v1/chat/completions
# Optional: use this when the model only accepts temperature=1.
# LLM_TEMPERATURE=1
# Optional: use this when the model only accepts a fixed top_p.
# LLM_TOP_P=0.95
